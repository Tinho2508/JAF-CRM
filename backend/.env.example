# Supabase
# Use service_role key (Settings > API > service_role) para bypass RLS.
# Se não tiver, use a anon key - mas a tabela whatsapp_messages precisa de
# uma politica RLS permissiva (veja migration_whatsapp_messages.sql).
SUPABASE_URL=https://mtahebtububylnmauzsa.supabase.co
SUPABASE_SERVICE_KEY=
# SUPABASE_ANON_KEY=    # fallback se nao tiver service_role

# Gemini via Cloudflare Worker (proxy ja configurado no frontend)
GEMINI_WORKER_URL=https://jaf-crm-gemini-proxy.joseailton-ailtontinho.workers.dev/

# Flask
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# WhatsApp Provider (opcional - configure ao escolher um provedor)
# WA_PROVIDER=twilio
# WA_ACCOUNT_SID=
# WA_AUTH_TOKEN=
# WA_FROM_NUMBER=
